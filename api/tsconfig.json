{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2021",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2020"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*", "*.ts"],
  "exclude": ["node_modules"]
}
